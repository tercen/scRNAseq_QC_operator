{
  "name": "scRNAseq QC",
  "description": "Computes QC metrics for single-cell RNA sequencing data.",
  "tags": [
    "omics",
    "sc-RNA-seq",
    "QC"
  ],
  "authors": [
    "tercen"
  ],
  "urls": [
    "https://github.com/tercen/scRNAseq_QC_operator"
  ],
  "properties": [
    {
      "kind": "StringProperty",
      "name": "pattern",
      "defaultValue": "^MT-",
      "description": "Regex pattern to find mitochondrial genes. See Seurat documentation."
    }
  ],
  "operatorSpec": {
    "kind": "OperatorSpec",
    "ontologyUri": "https://tercen.com/_ontology/tercen",
    "ontologyVersion": "1.0.0",
    "inputSpecs": [
      {
        "kind": "CrosstabSpec",
        "metaFactors": [
          {
            "kind": "MetaFactor",
            "name": "Row",
            "type": "",
            "description": "Genes/features",
            "ontologyMapping": "variable",
            "crosstabMapping": "row",
            "cardinality": "1..n",
            "factors": []
          },
          {
            "kind": "MetaFactor",
            "name": "Column",
            "type": "",
            "description": "Cells/observations",
            "ontologyMapping": "observation",
            "crosstabMapping": "column",
            "cardinality": "1..n",
            "factors": []
          }
        ],
        "axis": [
          {
            "kind": "AxisSpec",
            "metaFactors": [
              {
                "kind": "MetaFactor",
                "name": "Y-Axis",
                "type": "double",
                "description": "Expression values",
                "ontologyMapping": "measurement",
                "crosstabMapping": "y",
                "cardinality": "1",
                "factors": []
              }
            ]
          }
        ]
      }
    ],
    "outputSpecsV2": [
      {
        "kind": "OperatorJoinSpec",
        "joinOperators": [
          {
            "kind": "JoinOperator",
            "joinType": "left",
            "leftPair": {
              "kind": "ColumnPair",
              "lColumns": [
                "Column"
              ],
              "rColumns": [
                "Column"
              ]
            },
            "rightRelation": {
              "kind": "TableRelation",
              "attributes": [
                {
                  "kind": "Attribute",
                  "name": "nCount_RNA",
                  "type": "double"
                },
                {
                  "kind": "Attribute",
                  "name": "nFeature_RNA",
                  "type": "double"
                },
                {
                  "kind": "Attribute",
                  "name": "percent_mt",
                  "type": "double"
                }
              ]
            }
          }
        ]
      }
    ]
  }
}