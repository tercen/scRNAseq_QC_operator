{
  "name": "scRNAseq QC",
  "description": "Computes QC metrics for single-cell RNA sequencing data.",
  "tags": [
    "omics",
    "sc-RNA-seq",
    "QC"
  ],
  "authors": [
    "tercen"
  ],
  "urls": [
    "https://github.com/tercen/scRNAseq_QC_operator"
  ],
  "properties": [
    {
      "kind": "StringProperty",
      "name": "pattern",
      "defaultValue": "^MT-",
      "description": "Regex pattern to find mitochondrial genes. See Seurat documentation."
    }
  ],
  "operatorSpec": {
    "kind": "OperatorSpec",
    "ontologyUri": "https://tercen.com/_ontology/tercen",
    "ontologyVersion": "0.0.1",
    "inputSpecs": [
      {
        "kind": "CrosstabSpec",
        "metaFactors": [
          {
            "kind": "MetaFactor",
            "name": "Cell ID",
            "type": "",
            "description": "Cell identifier or name",
            "ontologyMapping": "observation",
            "crosstabMapping": "column",
            "cardinality": "1..n",
            "factors": []
          },
          {
            "kind": "MetaFactor",
            "name": "Gene Name",
            "type": "",
            "description": "Gene name",
            "ontologyMapping": "variable",
            "crosstabMapping": "row",
            "cardinality": "1..n",
            "factors": []
          }
        ],
        "axis": [
          {
            "kind": "AxisSpec",
            "metaFactors": [
              {
                "kind": "MetaFactor",
                "name": "Count Data",
                "type": "numeric",
                "description": "Count data for single-cell RNA sequencing",
                "ontologyMapping": "measurement",
                "crosstabMapping": "y",
                "cardinality": "1",
                "factors": []
              }
            ]
          }
        ]
      }
    ]
  }
}